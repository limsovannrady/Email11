{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    { "path": "/api/cron", "schedule": "* * * * *" }
  ],
  "functions": {
    "api/webhook.py":     { "maxDuration": 30, "runtime": "python3.12" },
    "api/cron.py":        { "maxDuration": 60, "runtime": "python3.12" },
    "api/set_webhook.py": { "maxDuration": 10, "runtime": "python3.12" }
  }
}
